{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mq.quest_questionnaire_trigger_catalog.v1",
  "title": "Quest Questionnaire Passive Trigger Catalog",
  "type": "object",
  "required": ["schemaVersion", "scenarioId", "package", "activity", "triggers"],
  "properties": {
    "schemaVersion": {
      "const": "mq.quest_questionnaire_trigger_catalog.v1"
    },
    "catalogVersion": {
      "type": "string"
    },
    "scenarioId": {
      "type": "string",
      "minLength": 1
    },
    "package": {
      "type": "string",
      "minLength": 1
    },
    "activity": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["triggerId"],
        "properties": {
          "triggerId": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.:-]+$"
          },
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "recommendedMode": false,
          "questionnaireMode": false,
          "questionnaireType": false,
          "questionnaireSequence": false,
          "blockId": false,
          "blockNumber": false,
          "flowMode": false,
          "finishBehavior": false,
          "nextPackage": false,
          "nextActivity": false,
          "score": false,
          "scoring": false,
          "exportBehavior": false,
          "participantState": false
        },
        "additionalProperties": {
          "type": ["string", "number", "boolean", "null"]
        }
      }
    },
    "recommendedMode": false,
    "questionnaireMode": false,
    "questionnaireType": false,
    "questionnaireSequence": false,
    "blockId": false,
    "blockNumber": false,
    "flowMode": false,
    "finishBehavior": false,
    "nextPackage": false,
    "nextActivity": false,
    "score": false,
    "scoring": false,
    "exportBehavior": false,
    "participantState": false
  },
  "additionalProperties": {
    "type": ["string", "number", "boolean", "null", "array", "object"]
  }
}
