{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "my-questionnaire-2d.lsl-chain-command.v1",
  "title": "MyQuestionnaireVR-2D LSL Chain Command",
  "type": "object",
  "required": ["command"],
  "allOf": [
    {
      "if": {
        "properties": {
          "command": { "const": "trigger" }
        },
        "required": ["command"]
      },
      "then": {
        "required": ["triggerId"],
        "propertyNames": {
          "enum": [
            "schemaVersion",
            "command",
            "sessionId",
            "invocationId",
            "experimentId",
            "scenarioId",
            "trialId",
            "chainId",
            "triggerId",
            "triggerSource",
            "triggerTimestampUtc",
            "triggerTimestampUnixMs"
          ]
        }
      }
    }
  ],
  "properties": {
    "schemaVersion": {
      "const": "my-questionnaire-2d.lsl-chain-command.v1"
    },
    "command": {
      "enum": ["startPlan", "continuePlan", "trigger", "clearPlan", "discoverHooks", "startQuestionnaire", "openApp", "goHome", "forceStopQuestionnaire", "ping"]
    },
    "sessionId": { "type": "string" },
    "invocationId": { "type": "string" },
    "experimentId": { "type": "string" },
    "scenarioId": { "type": "string" },
    "trialId": { "type": "string" },
    "triggerId": { "type": "string" },
    "triggerSource": { "type": "string" },
    "triggerTimestampUtc": { "type": "string" },
    "triggerTimestampUnixMs": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "string" }
      ]
    },
    "chainId": { "type": "string" },
    "chainStepId": { "type": "string" },
    "chainStepIndex": { "type": "integer", "minimum": 0 },
    "chainPlan": { "$ref": "my-questionnaire-2d.chain-plan.v1" },
    "chainPlanJson": { "type": "string" },
    "chainPlanBase64": { "type": "string" },
    "chainPlanPath": { "type": "string" },
    "participantId": { "type": "string" },
    "participantName": { "type": "string" },
    "language": { "enum": ["English", "Deutsch"] },
    "finishBehavior": { "enum": ["staySaved", "resumeCaller", "openNext"] },
    "callerPackage": { "type": "string" },
    "callerActivity": { "type": "string" },
    "nextPackage": { "type": "string" },
    "nextActivity": { "type": "string" },
    "targetPackage": { "type": "string" },
    "targetActivity": { "type": "string" },
    "autoCloseDelayMs": { "type": "integer", "minimum": 0 },
    "commandReplayLanguage": { "enum": ["English", "Deutsch"] },
    "commandReplayPlan": { "type": "object" }
  },
  "additionalProperties": true
}
