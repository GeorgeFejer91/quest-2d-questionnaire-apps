  "uiTextSource": "Assets/StreamingAssets/UIText.txt",
  "languages": [
    "English",
    "Deutsch"
  ],
  "participantFields": [
    {
      "id": "name",
      "type": "text",
      "required": true
    },
    {
      "id": "age",
      "type": "integer",
      "required": true
    },
    {
      "id": "gender",
      "type": "singleChoice",
      "required": true
    },
    {
      "id": "consent",
      "type": "checkbox",
      "required": true
    }
  ],
  "blocks": [
    {
      "id": "demographics",
      "type": "demographics"
    },
    {
      "id": "custom_slider",
      "type": "slider",
      "expectedItemCount": 2,
      "min": 0,
      "max": 100,
      "wholeNumbers": true,
      "anchors": {
        "left": "NO, not more than usual",
        "right": "YES, much more than usual"
      },
      "languages": {
        "English": {
          "items": [
            "I felt aware of my breathing.",
            "I felt aware of my body boundaries."
          ],
          "target": "Assets/StreamingAssets/Questions_English.txt"
        },
        "Deutsch": {
          "items": [
            "Ich war mir meiner Atmung bewusst.",
            "Ich war mir meiner Koerpergrenzen bewusst."
          ],
          "target": "Assets/StreamingAssets/Questions_Deutsch.txt"
        }
      }
    },
    {
      "id": "end",
      "type": "blackScreen"
    }
  ],
  "exports": {
    "destination": "Application.persistentDataPath/QuestionnaireExports",
    "formats": [
      "json",
      "csv"
    ]
  },
