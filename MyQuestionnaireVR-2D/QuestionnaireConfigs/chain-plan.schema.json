{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "my-questionnaire-2d.chain-plan.v1",
  "title": "MyQuestionnaireVR-2D Quest APK Chain Plan",
  "type": "object",
  "required": ["schemaVersion", "steps"],
  "properties": {
    "schemaVersion": {
      "const": "my-questionnaire-2d.chain-plan.v1"
    },
    "questionnaireId": {
      "type": "string"
    },
    "questionnaireVersion": {
      "type": "string"
    },
    "chainId": {
      "type": "string"
    },
    "defaultFinishBehavior": {
      "enum": ["staySaved", "resumeCaller", "openNext"]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "package"],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "enum": ["scenario", "questionnaire"]
          },
          "package": {
            "type": "string"
          },
          "activity": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "triggerId": {
            "type": "string"
          },
          "trigger": {
            "type": "object",
            "properties": {
              "type": {
                "enum": ["apkManifestTrigger", "passiveTrigger", "externalTrigger"]
              },
              "id": {
                "type": "string"
              },
              "triggerId": {
                "type": "string"
              },
              "allowRepeat": {
                "type": "boolean"
              },
              "repeatable": {
                "type": "boolean"
              }
            },
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          },
          "allowRepeat": {
            "type": "boolean"
          },
          "repeatable": {
            "type": "boolean"
          },
          "extras": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          }
        }
      }
    }
  }
}
